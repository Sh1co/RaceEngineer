{
  "root": "app/jetbrains",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "app/jetbrains",
        "command": "gradle buildPlugin"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "app/jetbrains",
        "command": "gradle test"
      }
    },
    "run": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "app/jetbrains",
        "command": "gradle runIde"
      }
    }
  }
}
